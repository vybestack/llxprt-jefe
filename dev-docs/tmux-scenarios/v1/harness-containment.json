{
  "schema": 1,
  "name": "harness-containment",
  "platform": "macos",
  "terminal": { "cols": 100, "rows": 30 },
  "workspace": {
    "mode": 448,
    "dirs": [
      { "path": "work", "mode": 493 },
      { "path": "work/sub", "mode": 493 }
    ],
    "files": [],
    "env": []
  },
  "steps": [
    { "op": "launch", "argv": ["jefe-harness-probe"], "env": [], "cwd": "work" },
    { "op": "wait", "source": "frame", "literal": "PROBE READY", "timeout_ms": 15000 },
    { "op": "text", "text": "run /bin/rm -rf sub\n" },
    { "op": "wait", "source": "frame", "literal": "RUN[1] EXIT 0", "timeout_ms": 15000 },
    { "op": "text", "text": "run /bin/ln -s /tmp sub\n" },
    { "op": "wait", "source": "frame", "literal": "RUN[2] EXIT 0", "timeout_ms": 15000 },
    {
      "op": "write",
      "file": {
        "path": "work/sub/jefe-harness-escape-evidence.txt",
        "content": { "utf8": "must never be written through the swapped ancestor" },
        "mode": 420
      }
    },
    { "op": "finish" }
  ],
  "secrets": []
}
