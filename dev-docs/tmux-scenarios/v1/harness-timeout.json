{
  "schema": 1,
  "name": "harness-timeout",
  "platform": "macos",
  "terminal": { "cols": 100, "rows": 30 },
  "workspace": {
    "mode": 448,
    "dirs": [{ "path": "work", "mode": 493 }],
    "files": [],
    "env": []
  },
  "steps": [
    {
      "op": "capture",
      "name": "slow-tool",
      "path": "bin/slow-tool",
      "behavior": {
        "stdout": "",
        "stderr": "",
        "exit_code": 0,
        "stdin_limit": 0,
        "hang": true,
        "spawn_child_hang": true
      }
    },
    { "op": "launch", "argv": ["jefe-harness-probe"], "env": [], "cwd": "work" },
    { "op": "wait", "source": "frame", "literal": "PROBE READY", "timeout_ms": 15000 },
    { "op": "text", "text": "run slow-tool\n" },
    {
      "op": "wait",
      "source": "frame",
      "literal": "THIS LITERAL NEVER APPEARS",
      "timeout_ms": 1500
    },
    { "op": "finish" }
  ],
  "secrets": []
}
