{
  "config": {
    "cols": 100,
    "rows": 32,
    "history_limit": 2000,
    "initial_wait_ms": 200,
    "assert_mode": "strict"
  },
  "macros": {
    "quit": {
      "params": [],
      "steps": [
        { "key": "C-q" },
        { "waitForExit": 3000 }
      ]
    }
  },
  "steps": [
    { "waitFor": "LLxprt Jefe" },
    { "capture": "merge-dashboard-oriented" },

    { "key": "p" },
    { "waitFor": "Pull Requests" },
    { "capture": "merge-pr-workspace" },

    { "key": "Enter" },
    { "waitFor": "pull" },
    { "capture": "merge-pr-detail" },

    { "key": "m" },
    { "waitFor": "Merge" },
    { "capture": "merge-confirmation" },

    { "key": "Enter" },
    { "wait": 500 },
    { "key": "Enter" },
    { "wait": 1000 },
    { "waitFor": "merged" },
    { "capture": "merged-result" },

    { "key": "Escape" },
    { "wait": 200 },
    { "key": "Escape" },
    { "wait": 200 },

    { "macro": "quit", "args": {} }
  ]
}
