{
  "config": {
    "cols": 120,
    "rows": 36,
    "history_limit": 4000,
    "initial_wait_ms": 100,
    "assert_mode": "strict"
  },
  "steps": [
    { "waitFor": "LLxprt Jefe" },
    { "key": "p" },
    { "waitFor": "Pull Requests" },
    { "capture": "pr-search-mode-entered" },

    { "key": "/" },
    { "wait": 200 },
    { "capture": "pr-search-input-focused" },

    { "type": "draft" },
    { "wait": 300 },
    { "expect": "draft" },
    { "capture": "pr-search-query-typed" },

    { "key": "Enter" },
    { "wait": 300 },
    { "capture": "pr-search-applied" },

    { "key": "Escape" },
    { "wait": 200 },
    { "key": "a" },
    { "waitFor": "No terminal attached" },

    { "key": "q" },
    { "key": "q" },
    { "key": "q" },
    { "waitForExit": 3000 }
  ]
}
