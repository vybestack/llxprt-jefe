    { "line": "stty -echo -icanon min 5 time 0; bytes=$(dd bs=5 count=1 2>/dev/null | od -An -tx1 | tr -d ' '); stty sane; printf 'issue355-f11-forwarded-%s\\n' \"$bytes\"" },
